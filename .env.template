# ════════════════════════════════════════════════════════════════
# Gelendzhik Guesthouse Automation — Environment Variables
# Скопировать в infrastructure/.env и заполнить
# НИКОГДА не коммитить .env в git!
# ════════════════════════════════════════════════════════════════

# ── POSTGRESQL ─────────────────────────────────────────────────
POSTGRES_DB=n8n_gelendzhik
POSTGRES_USER=n8n_user

# Сгенерировать: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── N8N 2.x ───────────────────────────────────────────────────
N8N_HOST=0.0.0.0

# Сгенерировать: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_here
WEBHOOK_URL=https://n8n.YOUR_DOMAIN.ru/
GENERIC_TIMEZONE=Europe/Moscow

# ── TELEGRAM БОТЫ ──────────────────────────────────────────────
# Создать у @BotFather → /newbot
TELEGRAM_OWNER_BOT_TOKEN=FILL_ME
TELEGRAM_GUEST_BOT_TOKEN=FILL_ME

# Узнать свой: написать @userinfobot
OWNER_CHAT_ID=FILL_ME

# ── CLAUDE API (Anthropic) ────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-FILL_ME
CLAUDE_MODEL=claude-sonnet-4-6-20260217

# ── REALTYCALENDAR ─────────────────────────────────────────────
RC_AGENCY_ID=79366

# iCal URLs
ICAL_APT_40=https://realtycalendar.ru/ical/302043.ics
ICAL_APT_41=https://realtycalendar.ru/ical/302052.ics
ICAL_APT_42=https://realtycalendar.ru/ical/310322.ics
ICAL_APT_50=https://realtycalendar.ru/ical/310313.ics

# ── БАЗОВЫЕ ЦЕНЫ ──────────────────────────────────────────────
PRICE_APT_40=4000
PRICE_APT_41=4500
PRICE_APT_42=4500
PRICE_APT_50=7000

# ── GOOGLE SHEETS ──────────────────────────────────────────────
GOOGLE_SHEETS_ID=FILL_ME

# ── HEALTHCHECKS.IO ────────────────────────────────────────────
HEALTHCHECK_ICAL_UUID=FILL_ME
HEALTHCHECK_PRICING_UUID=FILL_ME

# ── ПРОМОКОДЫ ──────────────────────────────────────────────────
